# App
NODE_ENV=development
PORT=4000
HTTP_PORT=80
PUBLIC_SOFA_LEADS_ENABLED=false
NODE_OPTIONS=--dns-result-order=ipv4first

# Database
# Option A: provide the full Prisma/PostgreSQL connection URL.
DATABASE_URL=postgresql://sofa_crm_user:change_this_postgres_password@localhost:5432/sofa_crm?schema=public

# Option B: leave DATABASE_URL unset and provide separate PostgreSQL variables.
# The Docker entrypoint will build DATABASE_URL automatically:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=sofa_crm
# POSTGRES_USER=sofa_crm_user
# POSTGRES_PASSWORD=change_this_postgres_password

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=sofa_crm_token
COOKIE_SECURE=false
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost

# First admin seed
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_LEAD_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=
# Lead notifications should go to a Telegram channel.
TELEGRAM_LEAD_CHANNEL_ID=
# Optional fallback for direct admin notifications.
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_PROXY_URL=

# Frontend dev/build
VITE_API_BASE_URL=/api
