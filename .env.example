# App
NODE_ENV=development
PORT=4000
HTTP_PORT=80
PUBLIC_SOFA_LEADS_ENABLED=false
NODE_OPTIONS=--dns-result-order=ipv4first

# Database
# Default Docker/Amvera mode: embedded PostgreSQL runs inside this container.
# Data is persisted in /data/postgres via amvera.yml persistenceMount.
EMBEDDED_POSTGRES_ENABLED=true
POSTGRES_PORT=5432
POSTGRES_DB=sona_bot
POSTGRES_USER=sona_user
POSTGRES_PASSWORD=change_this_embedded_postgres_password

# Optional external database mode:
# EMBEDDED_POSTGRES_ENABLED=false
# DATABASE_URL=postgresql://sofa_crm_user:change_this_postgres_password@db-host:5432/sofa_crm?schema=public
# or:
# POSTGRES_HOST=db-host

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=sofa_crm_token
COOKIE_SECURE=false
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost

# First admin seed
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_LEAD_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=
# Lead notifications should go to a Telegram channel.
TELEGRAM_LEAD_CHANNEL_ID=
# Optional fallback for direct admin notifications.
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_PROXY_URL=

# Frontend dev/build
VITE_API_BASE_URL=/api
