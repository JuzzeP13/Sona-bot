NODE_ENV=production
PORT=3000
NODE_OPTIONS=--dns-result-order=ipv4first

# Set this to your Amvera managed PostgreSQL connection string.
# Example host format: amvera-<username>-cnpg-<project_name>-rw
DATABASE_URL=postgresql://<db_user>:<db_password>@<internal_postgres_host>:5432/<db_name>?schema=public

# Alternative: if DATABASE_URL is not set, docker-start.mjs can build it from these.
# POSTGRES_HOST=amvera-<username>-cnpg-<project_name>-rw
# POSTGRES_PORT=5432
# POSTGRES_DB=<db_name>
# POSTGRES_USER=<db_user>
# POSTGRES_PASSWORD=<db_password>

JWT_SECRET=<long_random_secret>
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=sofa_crm_token
COOKIE_SECURE=true

# Replace with your real Amvera domain after it is created.
FRONTEND_ORIGIN=https://<your-app-domain>
CORS_ORIGINS=https://<your-app-domain>

PUBLIC_SOFA_LEADS_ENABLED=false

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<strong_admin_password>

TELEGRAM_ENABLED=false
TELEGRAM_LEAD_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_LEAD_CHANNEL_ID=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_PROXY_URL=
